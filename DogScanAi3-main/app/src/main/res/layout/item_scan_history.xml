<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Scanned Image -->
        <ImageView
            android:id="@+id/iv_scan_image"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:contentDescription="Scanned dog image" />

        <!-- Breed DB Image -->
        <ImageView
            android:id="@+id/iv_breed_info_image"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:contentDescription="Breed reference image" />

        <!-- Title + Badge Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_scan_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_scan_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#E3F2FD"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tv_scan_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp" />

        <!-- Confidence -->
        <TextView
            android:id="@+id/tv_scan_confidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <!-- Temperament -->
        <TextView
            android:id="@+id/tv_scan_temperament"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#5D4037"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Origin -->
        <TextView
            android:id="@+id/tv_scan_origin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_scan_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#424242"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>