<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Filter Toggle: Breed | Disease -->
    <LinearLayout
        android:id="@+id/filter_toggle"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/btn_breed"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:text="Breed"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#4A69FF"
            />

        <Button
            android:id="@+id/btn_disease"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:text="Disease"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Scan Frame Overlay -->
    <ImageView
        android:id="@+id/scan_frame"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_centerInParent="true"
        android:alpha="0.7" />

    <!-- Dynamic Hint Label -->
    <TextView
        android:id="@+id/scan_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/scan_frame"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="Position the dog to identify its breed"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <!-- Bottom Actions: Upload + Scan -->
    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- ✅ Upload Button — children are NOT clickable so parent gets the touch -->
        <LinearLayout
            android:id="@+id/upload_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="36dp"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/baseline_photo_library_24"
                android:contentDescription="Upload photo from gallery"
                android:clickable="false"
                android:focusable="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Upload"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <!-- Scan / Capture Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/capture_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/outline_photo_camera_24"
                android:contentDescription="Scan" />

            <TextView
                android:id="@+id/capture_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Scan Breed"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>